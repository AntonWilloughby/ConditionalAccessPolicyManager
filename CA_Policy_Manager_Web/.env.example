# Environment Configuration for Local Development

# Flask Environment (development, production, testing)
FLASK_ENV=development

# Secret key for sessions (generate new one with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here-change-in-production

# Azure AD OAuth Configuration
MSAL_CLIENT_ID=bcb41e64-e9a8-421c-9331-699dd9041d58
MSAL_AUTHORITY=https://login.microsoftonline.com/organizations

# Optional: Enable CSRF protection in development (recommended for testing)
ENABLE_CSRF=false

# Optional: Disable SSL verification for corporate proxy (use with caution)
# DISABLE_SSL_VERIFY=true

# Upload folder
UPLOAD_FOLDER=data/uploads

# Server configuration
PORT=5000
HOST=0.0.0.0

# ===================================================================
# AI Configuration (Optional - for AI Policy Explainer feature)
# ===================================================================

# Enable AI features
AI_ENABLED=false
AI_PROVIDER=azure  # Options: azure, openai, local

# Azure OpenAI (Recommended for enterprise)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# OpenAI (Alternative)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Local Model (Ollama - for air-gapped environments)
# LOCAL_MODEL=phi3

# ===================================================================
# IMPORTANT: DO NOT COMMIT THIS FILE WITH REAL SECRETS TO GIT
# Add .env to .gitignore
# ===================================================================
